# MongoDB
MONGODB_URI=mongodb://localhost:27017/iwords

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Telegram Bot (for bot.ts if needed)
BOT_TOKEN=your_bot_token
WEBAPP_URL=https://your-deployed-frontend.com

# Access control
# Your own Telegram user ID (the owner of all decks)
OWNER_USER_ID=your_telegram_id
# Comma-separated list of Telegram IDs that can view the owner's decks (read-only)
VIEWER_IDS=725868536
